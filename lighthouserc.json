{
  "ci": {
    "collect": {
      "staticDistDir": "frontend/dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/cours-echecs-adultes-geneve.html",
        "http://localhost/tarifs.html",
        "http://localhost/blog/sortir-du-plateau-1500-elo.html"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "//": "Lighthouse tourne sur les fichiers statiques en localhost : les scores SEO/a11y y sont faussés (canonical/hreflang pointent vers le domaine de prod, runner plus lent). On garde Lighthouse en RAPPORT (warn) — la vraie qualité est vérifiée contre le serveur Go en prod. Ne bloque pas le build.",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["warn", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.05 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 3000 }]
      }
    },
    "upload": { "target": "temporary-public-storage" }
  }
}
