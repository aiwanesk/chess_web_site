{
  "ci": {
    "collect": {
      "staticDistDir": "frontend/dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/cours-echecs-adultes-geneve.html",
        "http://localhost/tarifs.html",
        "http://localhost/blog.html"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "//": "BLOQUANT (error) sur les mesures FIABLES en localhost/statique : accessibilité, best-practices, layout shift. AVERTISSEMENT (warn) sur celles faussées par l'environnement : SEO (canonical/hreflang → domaine de prod), performance/LCP (runner CI plus lent). La perf réelle est validée contre le serveur Go.",
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.05 }],
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 3000 }]
      }
    },
    "upload": { "target": "temporary-public-storage" }
  }
}
