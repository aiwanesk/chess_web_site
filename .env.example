# Copy to .env and adjust. No secrets are ever hard-coded in the source.

# HTTP listen address for the Go server.
ADDR=:8080

# Public origin (no trailing slash). Used for canonical URLs, sitemap.xml,
# robots.txt and llms.txt. MUST match the deployed domain.
BASE_URL=https://iwanesko.ch

# Directory of blog Markdown, read at runtime for sitemap/llms.txt.
CONTENT_DIR=../content/blog

# DEVELOPMENT ONLY: serve the frontend from disk instead of the embedded build,
# so you don't rebuild the Go binary on every front-end change.
# Point it at the Vite output. Leave empty in production (uses embedded files).
DEV_STATIC_DIR=../frontend/dist

# Optional: forward contact-form submissions to an email relay / CRM webhook.
# Empty = submissions are only logged by the server.
CONTACT_WEBHOOK_URL=

# --- Batch « tactiques de la semaine » -------------------------------------
# PSEUDOS PRIVÉS : à définir dans .env (local) ou GitHub Secrets — JAMAIS ici,
# JAMAIS commités. La sortie du batch (puzzles) ne contient aucun identifiant.
CHESSCOM_USERNAME=
LICHESS_USERNAME=
# Token Lichess optionnel (limites API / analyse) — https://lichess.org/account/oauth/token
LICHESS_TOKEN=
# Secret du tableau de bord privé des stats (protège /admin). À définir en prod.
ADMIN_TOKEN=
